{
  "extraKnownMarketplaces": {
    "opsx-enhanced-flow": {
      "source": {
        "source": "github",
        "repo": "fritze-dev/opsx-enhanced-flow"
      }
    }
  },
  "enabledPlugins": {
    "opsx@opsx-enhanced-flow": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "claude plugin install opsx@opsx-enhanced-flow 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
